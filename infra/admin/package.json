    "@starkeep/admin-shared": "workspace:*",
    "sst": "^3.3.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.134",
    "@types/node": "^25.0.3",
    "typescript": "^5.3.3"
  }
}
