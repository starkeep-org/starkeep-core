# Starkeeper Control Plane Configuration

# ============================================================================
# DEPLOYMENT MODE
# ============================================================================
# Options: saas | selfhosted | selfhosted-multi
DEPLOYMENT_MODE=selfhosted

# ============================================================================
# DATABASE
# ============================================================================
# Provide your own database URL OR set USE_AURORA=true to create one
DATABASE_URL=postgresql://user:password@host:5432/starkeeper

# Set to "true" to create Aurora Serverless v2 (requires USE_VPC=true)
USE_AURORA=false
DB_MIN_CAPACITY=0.5 ACU
DB_MAX_CAPACITY=4 ACU

# ============================================================================
# NETWORKING
# ============================================================================
# Set to "true" to create VPC (recommended for production)
USE_VPC=false

# ============================================================================
# CUSTOM DOMAIN (Optional)
# ============================================================================
# DOMAIN_NAME=starkeeper.example.com
# ROUTE53_ZONE_ID=Z1234567890ABC

# ============================================================================
# AUTHENTICATION (Optional)
# ============================================================================
# For Remix session management
SESSION_SECRET=change-me-to-a-random-string

# OIDC/SSO Configuration (if using)
# OIDC_ISSUER=https://your-idp.com
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret

# ============================================================================
# AWS CONFIGURATION
# ============================================================================
# For SaaS mode: Your vendor account ID
# For self-hosted: Auto-detected from current AWS credentials
# AWS_ACCOUNT_ID=123456789012

# Default AWS region
AWS_REGION=us-east-1

# ============================================================================
# DEPLOYMENT STAGE
# ============================================================================
# Used by SST: dev | staging | production
# Set via: sst deploy --stage production
# STAGE=production
