{
  "name": "@starkeep/sdk",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@starkeep/protocol-primitives": "workspace:*",
    "@starkeep/storage-adapter": "workspace:*",
    "@starkeep/query-orchestrator": "workspace:*",
    "@starkeep/sync-engine": "workspace:*",
    "@starkeep/access-control": "workspace:*",
    "@starkeep/shared-space-api": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
