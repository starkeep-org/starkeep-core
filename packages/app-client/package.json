{
  "name": "@starkeep/app-client",
  "version": "0.3.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./load-env": {
      "types": "./dist/load-env-auto.d.ts",
      "import": "./dist/load-env-auto.js",
      "require": "./dist/load-env-auto.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/starkeep-dev/starkeep-core.git",
    "directory": "packages/app-client"
  },
  "homepage": "https://github.com/starkeep-dev/starkeep-core/tree/main/packages/app-client",
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@aws-sdk/client-ssm": "^3.700.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "aws-sdk-client-mock": "^4.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
