{
  "name": "@starkeep/builtin-cloud-data-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Built-in app: cloud broker (DSQL + files bucket + protocol-core Lambda + API Gateway). Installed by the admin-installer pipeline as the final step of bootstrap.",
  "scripts": {
    "build": "node build.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-ssm": "^3.700.0",
    "@aws-sdk/client-sts": "^3.700.0",
    "@aws-sdk/cloudfront-signer": "^3.700.0",
    "@aws-sdk/dsql-signer": "^3.700.0",
    "@aws-sdk/lib-storage": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@starkeep/protocol-primitives": "workspace:*",
    "@starkeep/shared-space-api": "workspace:*",
    "@starkeep/storage-adapter": "workspace:*",
    "@starkeep/storage-aurora-dsql": "workspace:*",
    "@starkeep/storage-s3": "workspace:*",
    "@starkeep/sync-engine": "workspace:*",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@starkeep/app-client": "workspace:*",
    "@types/aws-lambda": "^8.10.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "aws-sdk-client-mock": "^4.1.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.7"
  }
