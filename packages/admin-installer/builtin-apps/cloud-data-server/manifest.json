{
  "id": "cloud-data-server",
  "name": "Cloud Data Server",
  "version": "0.1.0",
  "tier": "official",
  "infraRequirements": {
    "fileAccess": [],
    "compute": {
      "enabled": true,
      "handlers": [
        {
          "name": "api",
          "handler": "api-handler.handler",
          "memoryMb": 256,
          "timeoutSeconds": 30,
          "routes": ["$default"]
        }
      ]
    },
    "brokerPower": true
  }
}
