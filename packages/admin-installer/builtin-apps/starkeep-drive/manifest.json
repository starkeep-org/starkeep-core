{
  "id": "starkeep-drive",
  "name": "Starkeep Drive",
  "version": "0.1.0",
  "tier": "official",
  "infraRequirements": {
    "sharedTypeAccess": [
      {
        "typeId": "*",
        "access": "readwrite",
        "metadataWrite": true,
        "rationale": "Drive owns cross-cutting custody of all shared user data, including syncing shared metadata for every type."
      }
    ],
    "compute": { "enabled": false },
    "brokerPower": false,
    "appSpecificSyncable": { "tables": [], "files": false }
  }
}
