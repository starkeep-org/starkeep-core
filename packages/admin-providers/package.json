{
  "name": "@starkeep/admin-providers",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./aws": {
      "types": "./dist/aws/index.d.ts",
      "import": "./dist/aws/index.js",
      "require": "./dist/aws/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@aws-sdk/client-cloudformation": "^3.645.0",
    "@aws-sdk/client-s3": "^3.645.0",
    "@aws-sdk/client-sts": "^3.645.0",
    "@aws-sdk/credential-providers": "^3.958.0"
  },
  "devDependencies": {
    "aws-sdk-client-mock": "^4.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
