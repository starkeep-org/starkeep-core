{
  "name": "@tasks/tasks-desktop",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "predev": "bash ../../scripts/check-browser-compat.sh",
    "prebuild": "bash ../../scripts/check-browser-compat.sh",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "tauri": "tauri",
    "sidecar:build": "mkdir -p src-tauri/binaries && bun build --compile sidecar/index.ts --outfile \"src-tauri/binaries/agent-sidecar-$(rustc --print host-triple)\""
  },
  "dependencies": {
    "@tasks/tasks-lib": "workspace:*",
    "@tasks/tasks-ui": "workspace:*",
    "@starkeep/core": "workspace:*",
    "@starkeep/sdk": "workspace:*",
    "@starkeep/storage-adapter": "workspace:*",
    "@starkeep/storage-sqlite": "workspace:*",
    "@starkeep/storage-fs": "workspace:*",
    "@anthropic-ai/sdk": "^0.39.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-sql": "^2.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
