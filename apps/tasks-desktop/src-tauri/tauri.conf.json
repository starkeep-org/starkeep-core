{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Starkeep Tasks",
  "version": "0.0.1",
  "identifier": "app.starkeep.tasks",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Starkeep Tasks",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "externalBin": ["binaries/agent-sidecar"]
  }
}
