{
  "name": "@starkeep/local-data-server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "data-server-ctl": "./cli.ts"
  },
  "scripts": {
    "start": "tsx server.ts",
    "dev": "tsx --watch server.ts",
    "cli": "tsx cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint *.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity": "^3.700.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.700.0",
    "@aws-sdk/dsql-signer": "^3.700.0",
    "@starkeep/protocol-primitives": "workspace:*",
    "@starkeep/query-orchestrator": "workspace:*",
    "@starkeep/sdk": "workspace:*",
    "@starkeep/shared-space-api": "workspace:*",
    "@starkeep/storage-adapter": "workspace:*",
    "@starkeep/storage-aurora-dsql": "workspace:*",
    "@starkeep/storage-fs": "workspace:*",
    "@starkeep/storage-s3": "workspace:*",
    "@starkeep/storage-sqlite": "workspace:*",
    "@starkeep/sync-engine": "workspace:*",
    "pg": "^8.13.0",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@starkeep/app-client": "workspace:*",
    "@starkeep/testkit": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
